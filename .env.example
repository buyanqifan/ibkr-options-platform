# IBKR Options Trading Platform
# Copy this file to .env and fill in your credentials

# IBKR Credentials (for IB Gateway Docker - extrange/ibkr image)
USERNAME=your_username
PASSWORD='your_password'  # Use single quotes if password contains $, /, or \

# IB Gateway Configuration
GATEWAY_OR_TWS=gateway
IBC_TradingMode=paper
IBC_ReadOnlyApi='no'
IBC_ExistingSessionDetectedAction=primaryonly
IBC_AutoRestart='yes'

# App Settings
IBKR_HOST=ibgateway
IBKR_PORT=8888
IBKR_CLIENT_ID=1
IBKR_TRADING_MODE=paper
APP_HOST=0.0.0.0
APP_PORT=8050
APP_DEBUG=false

# Database
DB_PATH=data/trading.db

# Logging
LOG_LEVEL=INFO
