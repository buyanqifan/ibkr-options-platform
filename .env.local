# 本地开发环境配置
# 用于本地开发和调试

# IBKR连接配置 (本地开发)
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
IBKR_TRADING_MODE=paper

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8050
APP_DEBUG=true

# 数据库路径
DB_PATH=data/trading.db

# 日志级别
LOG_LEVEL=DEBUG

# 缓存配置
REALTIME_CACHE_TTL=2
HISTORICAL_CACHE_TTL=300
FUNDAMENTALS_CACHE_TTL=86400

# API限流
API_REQUESTS_PER_SECOND=45